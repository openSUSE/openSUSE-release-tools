# Copy this file to /etc/default/osrt-check-bugowner-gitea-<instance_name>.env
# where <instance_name> is the name of the unit instance (which should also be
# the name of the build service/gitea user)

# GITEA_URL: The URL of the Gitea instance
GITEA_URL=https://src.opensuse.org"

# GITEA_ACCESS_USER: the name of the Gitea user
GITEA_ACCESS_USER="<INSERT_USER_HERE>"

# GITEA_ACCESS_TOKEN: the access token for the user
GITEA_ACCESS_TOKEN="<INSERT_TOKEN_HERE>"

# OSRT_BUGOWNER_LDAP_SERVER: The fully qualified domain name
# of the LDAP instance to query for bugowner active statuses.
# When unset, LDAP queries will be disabled.
OSRT_BUGOWNER_LDAP_SERVER="pan.suse.de"

# OSRT_BUGOWNER_LDAP_TIMEOUT: The number of seconds the
# check_bugower script will wait for a response when querying
# the LDAP instance
OSRT_BUGOWNER_LDAP_TIMEOUT="30"
